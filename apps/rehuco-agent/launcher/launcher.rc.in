// Icon ID 1 is what Windows uses for the default exe icon (Explorer, taskbar, pins)
1 ICON "@ICON_ABS_PATH@"

// FileDescription is what Explorer's "How do you want to open this file?" picker shows
// instead of the raw exe name -- without this block it falls back to "rehuco-agent-dev.exe".
1 VERSIONINFO
FILEVERSION 0,0,1,0
PRODUCTVERSION 0,0,1,0
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x40004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "borco"
            VALUE "FileDescription", "Rehuco Agent (dev launcher)"
            VALUE "FileVersion", "0.0.1.0"
            VALUE "ProductName", "Rehuco Agent"
            VALUE "ProductVersion", "0.0.1.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
