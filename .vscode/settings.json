{
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        }
    },
    "ruff.enable": true,
    "yaml.customTags": [
        "tag:yaml.org,2002:python/name:material.extensions.emoji.twemoji scalar",
        "tag:yaml.org,2002:python/name:material.extensions.emoji.to_svg scalar"
    ],
    "flake8.enabled": false,
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
    "pylint.enabled": false,
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "better-todo-tree.general.showActivityBarBadge": true,
    "better-todo-tree.general.showIconsInsteadOfTagsInStatusBar": true,
    "better-todo-tree.general.statusBar": "total",
    "better-todo-tree.filtering.excludeGlobs": [
        "**/node_modules/*/**",
        "**/*.md"
    ],
    "better-todo-tree.filtering.ignoreGitSubmodules": true,
    "claudeCode.respectGitIgnore": false,
    "cmake.ignoreCMakeListsMissing": true,
    "makefile.configureOnOpen": false,
}
